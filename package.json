    "vitest": "^3.0.0"
  },
  "resolutions": {
    "node-fetch": "^2.6.7",
    "vite": "^6.0.0"
  },
  "overrides": {
    "node-fetch": "^2.6.7",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "sharp",
      "sqlite3",
      "workerd"
    ]
