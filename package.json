  "license": "UNLICENSED",
  "private": true,
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "build": "turbo build",
    "test": "turbo run test",
    "test:ci": "CI=true turbo run test:ci --filter='!./packages/apps/session-storage/*'",
